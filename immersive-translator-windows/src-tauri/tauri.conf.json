{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ImmersiveTranslator",
  "version": "0.1.0",
  "identifier": "com.immersivetranslator.windows",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/tray-icon.png",
      "tooltip": "ImmersiveTranslator"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
