{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ImmersiveTranslator",
  "version": "0.1.0",
  "identifier": "com.immersivetranslator.windows",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "panel",
        "title": "",
        "width": 440,
        "height": 320,
        "minWidth": 320,
        "minHeight": 200,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": true
      },
      {
        "label": "settings",
        "title": "ImmersiveTranslator 设置",
        "width": 640,
        "height": 580,
        "resizable": true,
        "minimizable": true,
        "maximizable": false,
        "visible": false,
        "center": true
      },
      {
        "label": "history",
        "title": "翻译历史",
        "width": 720,
        "height": 560,
        "resizable": true,
        "minimizable": true,
        "maximizable": false,
        "visible": false,
        "center": true
      },
      {
        "label": "ocr-overlay",
        "title": "",
        "fullscreen": true,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM1MzlBRjU2NjMzNjNCNzIKUldSeU96WmpWcTg1TlpzOEVYTjlnaFRmclM3OWFLSDVsbjRKQmZVcHFRU3hzTmJzWVE1VzRWTEYK",
      "endpoints": [
        "https://github.com/kobejiasuoer/immersive-translator/releases/latest/download/latest.json"
      ]
    }
  }
}
